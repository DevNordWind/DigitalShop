bot:
  token: your_token

  super_admins:
    - 123321

  webhook:
    base_url: https://example.com
    secret: your_secret_token
    with_ip_filter: false # This option available only with reverse proxy

file_storage:
  base_path: ./data/files

payment:
  crypto_pay:
    token: your_token
    network: https://pay.crypt.bot/

postgres:
  db: YourDatabaseName
  host: postgres
  port: 5432
  username: postgres
  password: 1234

  driver: psycopg

  sql_alchemy:
    echo: false
    hide_parameters: true
    pool_pre_ping: true

    max_overflow: 15
    pool_size: 20

redis:
  db: 0
  host: localhost
  port: 6379
  password: null
  username: null

log:
  # Logging settings | 10 - DEBUG; 20 - INFO; 30 - WARNING; 40 - ERROR; 50 - CRITICAL
  console_level: 20
  file_level: 30

  path_log: ./data/logs
